#!/usr/bin/env bash
set -euo pipefail

IMAGE_NAME="sandclaude"
CLAUDE_CONFIG="$HOME/.claude"

usage() {
    echo "Usage: sandclaude [-s] [-b] [-r] [-h] [workspace]"
    echo ""
    echo "Run Claude Code in a Docker container."
    echo ""
    echo "Options:"
    echo "  -s    Open bash shell instead of claude"
    echo "  -b    Force rebuild of the Docker image"
    echo "  -r    Resume the previous claude session"
    echo "  -h    Show this help message"
    echo ""
    echo "Arguments:"
    echo "  workspace   Path to mount inside the container (default: current directory)"
}

SHELL_MODE=false
FORCE_BUILD=false
RESUME=false
while getopts "sbrh" opt; do
    case "$opt" in
        s) SHELL_MODE=true ;;
        b) FORCE_BUILD=true ;;
        r) RESUME=true ;;
        h) usage; exit 0 ;;
        *) usage; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

WORKSPACE="$(cd "${1:-$(pwd)}" && pwd -P)"

# Follow symlinks to find the real script location (macOS-compatible)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd -P)"
    SOURCE="$(readlink "$SOURCE")"
    [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd -P)"

build_image() {
    if [ ! -f "$SCRIPT_DIR/Dockerfile" ]; then
        echo "Error: No Dockerfile found in $SCRIPT_DIR"
        exit 1
    fi
    echo "Building $IMAGE_NAME image..."
    docker build \
        --build-arg USER_ID="$(id -u)" \
        --build-arg GROUP_ID="$(id -g)" \
        -t "$IMAGE_NAME" \
        "$SCRIPT_DIR"
}

# Check if image needs (re)building
needs_build() {
    if ! docker image inspect "$IMAGE_NAME" &>/dev/null; then
        return 0
    fi
    if [ ! -f "$SCRIPT_DIR/Dockerfile" ]; then
        return 1
    fi
    # Compare Dockerfile modification time to image creation time
    local dockerfile_mtime image_created image_epoch
    if [[ "$OSTYPE" == darwin* ]]; then
        dockerfile_mtime=$(stat -f %m "$SCRIPT_DIR/Dockerfile")
    else
        dockerfile_mtime=$(stat -c %Y "$SCRIPT_DIR/Dockerfile")
    fi
    image_created=$(docker inspect -f '{{.Created}}' "$IMAGE_NAME" 2>/dev/null || echo "")
    if [ -z "$image_created" ]; then
        return 0
    fi
    if [[ "$OSTYPE" == darwin* ]]; then
        image_epoch=$(date -j -f "%Y-%m-%dT%H:%M:%S" "${image_created%%.*}" +%s 2>/dev/null || echo 0)
    else
        image_epoch=$(date -d "$image_created" +%s 2>/dev/null || echo 0)
    fi
    [ "$dockerfile_mtime" -gt "$image_epoch" ]
}

if [ "$FORCE_BUILD" = true ] || needs_build; then
    build_image
fi

clear
echo "Starting Claude Code in: $WORKSPACE"

# Extract tokens for use inside the container
GH_TOKEN="$(gh auth token 2>/dev/null || true)"

# On macOS, Claude stores OAuth credentials in the Keychain, not in files.
# Extract them so the entrypoint can write them for Linux Claude Code.
CLAUDE_CREDENTIALS=""
if [[ "$OSTYPE" == darwin* ]]; then
    CLAUDE_CREDENTIALS="$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null || true)"
fi

DOCKER_ARGS=(
    --rm -it
    -v "$CLAUDE_CONFIG:/home/claude/.claude"
    -v "$HOME/.claude.json:/home/claude/.claude.json"
    -v "$HOME/.config/gh:/home/claude/.config/gh:ro"
    ${GH_TOKEN:+-e GH_TOKEN="$GH_TOKEN"}
    ${CLAUDE_CREDENTIALS:+-e CLAUDE_CREDENTIALS="$CLAUDE_CREDENTIALS"}
    -v "$WORKSPACE:$WORKSPACE"
    -w "$WORKSPACE"
)

if [ "$SHELL_MODE" = true ]; then
    exec docker run "${DOCKER_ARGS[@]}" --entrypoint /bin/bash "$IMAGE_NAME"
elif [ "$RESUME" = true ]; then
    exec docker run "${DOCKER_ARGS[@]}" "$IMAGE_NAME" --resume
else
    exec docker run "${DOCKER_ARGS[@]}" "$IMAGE_NAME"
fi
